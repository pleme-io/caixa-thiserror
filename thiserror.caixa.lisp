   :body "[package]\nname = \"thiserror_no_std_test\"\nversion = \"0.0.0\"\nauthors = [\"David Tolnay <dtolnay@gmail.com>\"]\nedition = \"2021\"\npublish = false\n\n[lib]\npath = \"test.rs\"\n\n[dependencies]\nthiserror = { path = \"../..\", default-features = false }\n"} {:path "tests/no-std/test.rs"
