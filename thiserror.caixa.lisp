   :body "// https://github.com/dtolnay/thiserror/issues/163\n\nuse std::backtrace::Backtrace;\nuse thiserror::Error;\n\n#[derive(Error, Debug)]\n#[error(\"...\")]\npub struct Error(\n    #[from]\n    #[backtrace]\n    std::io::Error,\n    Backtrace,\n);\n\nfn main() {}\n"} {:path "tests/ui/transparent-enum-not-error.stderr"
