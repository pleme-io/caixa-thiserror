   :body "use core::error::{Error, Request};\n\n#[doc(hidden)]\npub trait ThiserrorProvide: Sealed {\n    fn thiserror_provide<'a>(&'a self, request: &mut Request<'a>);\n}\n\nimpl<T> ThiserrorProvide for T\nwhere\n    T: Error + ?Sized,\n{\n    #[inline]\n    fn thiserror_provide<'a>(&'a self, request: &mut Request<'a>) {\n        self.provide(request);\n    }\n}\n\n#[doc(hidden)]\npub trait Sealed {}\nimpl<T: Error + ?Sized> Sealed for T {}\n"} {:path "src/private.rs"
